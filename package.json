{
  "name": "cypress",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "report:custom": "node merge-reports.js",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "cypress run",
    "test:open": "cypress open",
    "test:auth": "cypress run --spec 'cypress/e2e/login.cy.js'",
    "test:products": "cypress run --spec 'cypress/e2e/product-crud.cy.js'",
    "test:users": "cypress run --spec 'cypress/e2e/user-crud.cy.js'",
    "test:stock": "cypress run --spec 'cypress/e2e/stock-management.cy.js'",
    "cy:run:record": "cypress run --record",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:headed": "cypress run --headed",
    "test:with-videos": "cypress run --config video=true",
    "clean:media": "rimraf cypress/screenshots cypress/videos cypress/downloads",
    "clean:all": "rimraf cypress/screenshots cypress/videos cypress/downloads cypress/reports",
    "report:clean": "if exist cypress\\reports\\mochawesome rmdir /s /q cypress\\reports\\mochawesome && mkdir cypress\\reports\\mochawesome",
    "report:merge": "mochawesome-merge cypress/reports/mochawesome/*.json > cypress/reports/mochawesome/final-report.json",
    "report:generate": "marge cypress/reports/mochawesome/final-report.json --reportDir cypress/reports/mochawesome --inline",
    "report:open": "start cypress/reports/mochawesome/final-report.html",
    
    "test:report": "npm run report:clean && npm run cy:run && npm run report:merge && npm run report:generate",
    "test:report:open": "npm run test:report && npm run report:open"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "cypress": "^15.10.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^4.4.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
